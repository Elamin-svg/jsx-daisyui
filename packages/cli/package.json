{
  "name": "jsx-daisyui",
  "version": "1.0.1",
  "description": "A CLI tool to add jsx-daisyui components directly into your React project.",
  "keywords": [
    "daisyui",
    "react",
    "components",
    "cli",
    "tailwind",
    "ui"
  ],
  "author": "Elamin-svg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elamin-svg/jsx-daisyui.git"
  },
  "homepage": "https://jsx-daisyui.com",
  "bugs": {
    "url": "https://github.com/Elamin-svg/jsx-daisyui/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "jsx-daisyui": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.8.0"
  }
}
